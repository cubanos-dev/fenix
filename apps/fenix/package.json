{
  "name": "@fenix/fenix",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "bun --bun next dev --port 3002",
    "build": "bun --bun next build",
    "start": "bun --bun next start --port 3002",
    "lint": "biome check .",
    "test": "vitest run",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "validate": "tsc --noEmit && biome check ."
  },
  "dependencies": {
    "@fenix/ui": "workspace:*",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@fenix/biome-config": "workspace:*",
    "@fenix/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
