{
  "name": "@fenix/fenix",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "bun --bun next dev --port 3002",
    "build": "bun --bun next build",
    "start": "bun --bun next start --port 3002",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "validate": "tsc --noEmit && biome check ."
  },
  "dependencies": {
    "@fenix/ui": "workspace:*",
    "clsx": "2.1.1",
    "geist": "1.7.1",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@fenix/biome-config": "workspace:*",
    "@fenix/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "4.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "postcss": "8.5.15",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
