{
  "name": "fenix",
  "private": true,
  "packageManager": "bun@1.3.2",
  "workspaces": ["apps/*", "packages/*", "packages/config/*"],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "cd apps/api && ./dev.sh",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "validate": "turbo validate",
    "e2e": "turbo e2e",
    "db:migrate": "bun run --cwd apps/app lib/migrator.ts",
    "env:pull": "vercel env pull .env.local",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.5.0"
  }
}
