{
  "name": "fenix",
  "private": true,
  "packageManager": "bun@1.3.2",
  "workspaces": ["apps/*", "packages/*", "packages/config/*"],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "cd apps/api && ./dev.sh",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "validate": "turbo validate",
    "e2e": "turbo e2e",
    "db:migrate": "bun run --cwd apps/app lib/migrator.ts",
    "env:pull": "vercel env pull .env.local",
    "prepare": "lefthook install",
    "init": "bun run scripts/init-project.ts",
    "init:dry": "bun run scripts/init-project.ts --dry",
    "init:smoke": "bun run scripts/init-project.ts --smoke",
    "test:scripts": "bun test scripts",
    "coverage:audit": "bun run scripts/coverage-audit.ts",
    "pattern:audit": "bun run scripts/pattern-audit.ts",
    "pen:extract": "bun run scripts/pen-extract.ts",
    "pen:drift": "bun run scripts/pen-drift-check.ts",
    "pen:tokens": "bun run scripts/pen-tokens.ts",
    "visual:diff": "bun run scripts/visual-diff.ts",
    "phase:gate": "bun run scripts/phase-gate.ts"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.5.0"
  }
}
