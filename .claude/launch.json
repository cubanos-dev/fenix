{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["turbo", "dev", "--filter=@fenix/web"],
      "port": 3000
    },
    {
      "name": "api",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd apps/api && ./dev.sh"],
      "port": 8000
    },
    {
      "name": "app",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["turbo", "dev", "--filter=@fenix/app"],
      "port": 3001
    },
    {
      "name": "storybook-web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--cwd", "apps/web", "storybook"],
      "port": 6006
    },
    {
      "name": "storybook-app",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--cwd", "apps/app", "storybook"],
      "port": 6007
    }
  ]
}
