# =============================================================================
# Fenix — Environment Variables
# =============================================================================
# Copy to .env.local: cp .env.example .env.local
# Or pull from Vercel: vercel env pull .env.local

# Database (Neon Postgres via Vercel Marketplace)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host/db?sslmode=require"

# Auth (BetterAuth)
BETTER_AUTH_SECRET=""                    # min 32 chars, generate: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"

# OAuth — Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth — GitHub (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="App <onboarding@resend.dev>"

# File Storage (Cloudflare R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# AI (Vercel AI Gateway — auto-provisioned via vercel env pull)
# No manual API keys needed when using AI Gateway with OIDC
# VERCEL_OIDC_TOKEN is auto-provisioned

# =============================================================================
# Fenix loop — local-only (not pulled from Vercel; set per-developer)
# =============================================================================

# Pencil CLI auth — used by the Stage 2 design-runner agent to author and
# iterate `pens/<version>.pen`. Without this the design stage cannot run.
# Get yours from your Pencil account settings.
PENCIL_CLI_KEY=""

# Optional: override the location of the loop's read-model SQLite database.
# Default is .planning/fenix.db at the repo root.
# FENIX_DB=".planning/fenix.db"
